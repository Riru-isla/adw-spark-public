# GitHub
GITHUB_TOKEN=your_github_token

# Default stack (rails+vue, rails+react, phoenix+react, etc.)
SPARK_DEFAULT_STACK=rails+vue

# Default run mode (sketch, plan, build, ship)
SPARK_DEFAULT_MODE=sketch

# Projects directory (where generated projects will be created)
SPARK_PROJECTS_DIR=.projects

# Claude model preferences
SPARK_PLANNER_MODEL=opus
SPARK_WORKER_MODEL=sonnet
SPARK_GATE_MODEL=sonnet
